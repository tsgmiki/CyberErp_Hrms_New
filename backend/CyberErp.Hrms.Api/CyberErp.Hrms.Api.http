# ===========================================
# AUTH CONTROLLER
# ===========================================

# Login
POST {{CyberErp.Hrms.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userName": "johndoe",
  "password": "Password123!"
}

###
# Logout
POST {{CyberErp.Hrms.Api_HostAddress}}/api/auth/logout
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
  "tokenId": "your-token-id-here"
}

###
# Register (Create new tenant and user)
POST {{CyberErp.Hrms.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "fullName": "John Doe",
  "email": "john.doe@example.com",
  "phoneNumber": "+1234567890",
  "userName": "johndoe",
  "password": "Password123!",
  "tenantName": "John's Business",
  "tenantIdentifier": "john-business",
  "tenantAddress": "123 Main Street",
  "tenantPhoneNumber": "+1234567890"
}

###
# Register with Google
POST {{CyberErp.Hrms.Api_HostAddress}}/api/auth/register/google
Content-Type: application/json

{
  "fullName": "John Doe",
  "email": "meftuhharar@gmail.com",
  "phoneNumber": "+1234567890",
  "tenantName": "John's Business",
  "tenantIdentifier": "john-business-2",
  "tenantAddress": "123 Main Street",
  "tenantPhoneNumber": "+1234567890",
  "googleToken": "your-google-id-token-here"
}

